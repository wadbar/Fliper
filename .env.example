# FLIPEROS: ULTIMATE ARCHITECTURE (v2.0-ULTIMATE)
# PROFESSIONAL ENVIRONMENT CONFIGURATION BLUEPRINT

# [1] ==================== KERNEL & SYSTEM ====================
# The active running environment (e.g., 'development', 'production', 'test')
NODE_ENV=production

# Core HTTP Routing Port (Strictly managed by orchestrator)
PORT=3000

# Secret for session management or internal auth
SYSTEM_SECRET=change_me_to_something_ultra_secure_b64

# [2] ==================== NEURAL NETWORK & AI ====================
# Google Gemini API Key for metadata enrichment and predictive NLP control.
GEMINI_API_KEY=your_gemini_api_key_here

# Local Fallback URL for Ollama / LLaMA3
OLLAMA_BASE_URL=http://localhost:11434

# [3] ==================== ISOLATION & STORAGE ====================
# Simulated cgroup memory limits (in MB). Used by KernelProxy.
CGROUP_MEM_LIMIT_MB=1024

# Defines allowed execution directories for Kernel Shell proxy
ALLOWED_DIR=/app/data

# Root URL for asset downloading (Covers, Fanart, ROMs)
VITE_DOWNLOAD_MIRROR=https://archive.org/download/fliper_assets

# [4] ==================== TELEMETRY & OBSERVABILITY ====================
# Enable real-time file system stdout stream via logger.ts
ENABLE_FILE_LOGGING=true

# External webhook endpoint for fatal error alerting
WEBHOOK_ALERT_URL=
DISCORD_WEBHOOK_URL=
