# FLIPEROS SOVEREIGN KERNEL: CONFIGURATION EXAMPLE
# Copy to .env and fill with your high-performance credentials.

# 1. AI ENGINES (Neural Resiliency Tier)
# Tier 1: Local Inference
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Tier 2: Cloud Hyper-Context (REQUIRED)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Tier 3: Extreme Performance Barrier
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 2. SYSTEM INFRASTRUCTURE
NODE_ENV=development
PORT=3000

# 3. KERNEL PROXY & SECURITY
KERNEL_SECRET=generate_a_long_random_string_here
SECURITY_SALT=fliper_os_nitro_engine
